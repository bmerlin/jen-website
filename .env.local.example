# Copy to .env.local and fill in. Both files are gitignored.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-28

# Write token from sanity.io/manage → API → Tokens. Used only by scripts/seed.ts.
SANITY_WRITE_TOKEN=

# Viewer-only token, used by `next build` to fetch content. Set this in
# Cloudflare's Worker env vars too — it's read by the server-side build only,
# never exposed to the browser.
SANITY_API_READ_TOKEN=
